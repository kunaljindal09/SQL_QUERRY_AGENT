# LLM Provider Configuration
LLM_PROVIDER=llama
LLAMA_BASE_URL=https://aimodels.jadeglobal.com:8082/ollama/api
LLAMA_MODEL=deepseek-coder:6.7b
LLAMA_VERIFY_SSL=false

# Alternative LLM Provider
GOOGLE_API_KEY=your-google-api-key

# Database Configuration
# App database (users, auth, query history)
APP_DATABASE_URL=mysql+aiomysql://root:M%40nu3112@localhost:3306/sqlquerrydb

# Default target database (sample/demo data for querying)
DEFAULT_TARGET_DB_URL=mysql+aiomysql://root:M%40nu3112@localhost:3306/sql_agent_db

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Query Configuration
MAX_QUERY_ROWS=100
QUERY_TIMEOUT_SECONDS=30
MAX_QUESTION_LENGTH=5000
